{
  "name": "react-electron",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "d3": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1",
    "wait-on": "^8.0.0",
    "web-vitals": "^2.1.4"
  },
  "main": "build/electron.js",
  "homepage": "./",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "postbuild": "node -e \"const fs = require('fs'); fs.copyFileSync('public/main.js', 'build/electron.js'); fs.copyFileSync('public/preload.js', 'build/preload.js');\"",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron:serve": "concurrently -k \"cross-env BROWSER=none npm start\" \"npm run electron:start\"",
    "electron:build": "electron-builder",
    "electron:start": "wait-on tcp:3000 && electron ."
  },
  "description": "SpaceSense: Visualize your Computer Space. Electron + React app.",
  "author": "Rushikesh",
  "build": {
    "appId": "com.spacesense.app",
    "files": [
      "build/**/*",
      "public/main.js",
      "public/preload.js",
      "public/SpaceSenseLogo.ico"
    ],
    "extraResources": [
      {
        "from": "public/SpaceSenseLogo.ico",
        "to": "SpaceSenseLogo.ico"
      }
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "icon": "public/SpaceSenseLogo.ico",
      "target": "nsis"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "electron": "^32.0.2",
    "electron-builder": "^25.0.5"
  }
}
